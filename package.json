{
  "name": "gm-dashboard",
  "version": "1.0.0",
  "description": "GM Dashboard — Electron App for RPG Game Masters",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "vite build && electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "Genkai",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "howler": "^2.2.4",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.genkai.gmdashboard",
    "productName": "GENKAI GM Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "1040",
      "installerLanguages": [
        "it"
      ],
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Maruga",
      "repo": "gm-dashboard"
    }
  }
}
